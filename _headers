# Cloudflare Pages headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# Everything under /assets/ is content-addressed by hand: if a video or poster
# changes, its filename changes (or you re-run encode.sh and redeploy). So it is
# safe to cache these forever. This is what makes repeat visits instant.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=604800
/favicon-32.png
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800

# index.html must NOT be cached long — otherwise visitors keep seeing the old
# page after you deploy. Revalidate on every request; it is only ~37 KB.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Baseline security headers for a static site with no forms and no third-party JS.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
